<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_grey" />
            <corners android:radius="8dp" />
            <padding android:right="12dp" />
        </shape>
    </item>
    <item android:gravity="end|center_vertical" android:width="24dp" android:height="24dp">
        <rotate android:fromDegrees="0" android:toDegrees="270">
            <shape android:shape="rectangle">
                <solid android:color="@android:color/transparent" />
                <corners android:radius="4dp" />
                <size android:width="4dp" android:height="12dp" />
            </shape>
        </rotate>
        <bitmap android:src="@drawable/ic_dropdown_arrow" android:gravity="center" android:tint="@color/teal" />
    </item>
</layer-list>