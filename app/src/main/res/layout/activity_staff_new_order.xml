<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper"
    tools:context=".StaffActivity">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/logo_transparent"
        android:contentDescription="Restaurant Logo"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvOrderHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:fontFamily="@font/black_ops_one"
        android:letterSpacing="0.1"
        android:text="New Order"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardOrderForm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        android:layout_marginTop="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvOrderHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/rounded_translucent_bg">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilStaffName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Staff Member"
                    app:hintTextColor="@color/burgundy"
                    app:boxStrokeColor="@color/burgundy">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStaffName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:fontFamily="@font/black_ops_one"
                        android:textColor="@color/white"
                        android:textCursorDrawable="@drawable/grey_cursor" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCustomerName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Customer Name"
                    app:hintTextColor="@color/burgundy"
                    app:boxStrokeColor="@color/burgundy"
                    app:startIconDrawable="@drawable/ic_person"
                    app:startIconTint="@color/burgundy">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCustomerName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/black_ops_one"
                        android:inputType="textPersonName"
                        android:textColor="@color/white"
                        android:textCursorDrawable="@drawable/grey_cursor" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRestaurantName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Restaurant Name"
                    app:hintTextColor="@color/burgundy"
                    app:boxStrokeColor="@color/burgundy">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRestaurantName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/black_ops_one"
                        android:inputType="text"
                        android:textColor="@color/white"
                        android:textCursorDrawable="@drawable/grey_cursor" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilItemName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Item Name"
                    app:hintTextColor="@color/burgundy"
                    app:boxStrokeColor="@color/burgundy">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etItemName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/black_ops_one"
                        android:inputType="text"
                        android:textColor="@color/white"
                        android:textCursorDrawable="@drawable/grey_cursor" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Quantity -->
                <LinearLayout
                    android:id="@+id/qtyContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quantity:"
                        android:textColor="@color/white"
                        android:fontFamily="@font/black_ops_one"
                        android:layout_marginEnd="16dp"/>

                    <NumberPicker
                        android:id="@+id/numberPickerQty"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:theme="@style/ThemeOverlay.MaterialComponents.MaterialAlertDialog" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTime"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Time"
                    app:hintTextColor="@color/burgundy"
                    app:boxStrokeColor="@color/burgundy">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:fontFamily="@font/black_ops_one"
                        android:textColor="@color/white"
                        android:textCursorDrawable="@drawable/grey_cursor" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitOrder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/black_ops_one"
                    android:text="SUBMIT ORDER"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/burgundy"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
