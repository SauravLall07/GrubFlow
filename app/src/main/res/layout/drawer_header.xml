<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/toolbar_gradient"
        android:padding="16dp">

        <View
            android:id="@+id/textBackground"
            android:layout_width="wrap_content"
            android:layout_height="120dp"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="120dp"
            android:layout_marginBottom="1dp"
            android:background="@drawable/rounded_translucent_bg"
            android:elevation="2dp" />

        <TextView
            android:id="@+id/tvMemberName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignStart="@id/textBackground"
            android:layout_alignTop="@id/textBackground"
            android:layout_alignEnd="@id/textBackground"
            android:layout_alignBottom="@id/textBackground"
            android:layout_margin="10dp"
            android:elevation="10dp"
            android:fontFamily="@font/black_ops_one"
            android:gravity="center"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:text="STAFF"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgSloth"
            android:layout_width="120dp"
            android:layout_height="170dp"
            android:layout_alignBottom="@id/textBackground"
            android:layout_alignParentStart="true"
            android:layout_marginStart="0dp"
            android:layout_marginTop="8dp"
            android:contentDescription="@string/sloth_icon"
            android:elevation="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_transparent" />
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>