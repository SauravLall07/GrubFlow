<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MainApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->

        <!-- Add this line to change cursor color to grey -->
        <item name="colorControlActivated">@color/grey</item>
    </style>

    <style name="Theme.MainApplication" parent="Base.Theme.MainApplication" />

    <!-- SPLASH THEME -->
    <style name="Theme.MainApplication.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/dark_grey</item>
        <item name="android:statusBarColor">@color/dark_grey</item>
        <item name="android:navigationBarColor">@color/dark_grey</item>
        <item name="android:windowLightStatusBar">false</item> <!-- light icons for dark background -->
    </style>


</resources>